using System;
using System.Collections.Generic;
using System.Text.Json;
using System.Threading.Tasks;
using Microsoft.EntityFrameworkCore;
using {{ .Project.Name | pascalcase }}.Domain.Entities;
using {{ .Project.Name | pascalcase }}.Domain.Shared;
using {{ .Project.Name | pascalcase }}.Infrastructure.Persistence;
using Microsoft.Extensions.Logging;

namespace {{ .Project.Name | pascalcase }}.Infrastructure.Persistence.Seeders;

/// <summary>
/// Database seeder that applies seed data into the database.
/// seedValueExpression is defined in _helpers.cs.tmpl (loaded via bridge.yaml helpers).
/// </summary>
public class DomainSeeder
{
    private readonly DomainDbContext _context;
    private readonly ILogger<DomainSeeder> _logger;

    public DomainSeeder(DomainDbContext context, ILogger<DomainSeeder> logger)
    {
        _context = context ?? throw new ArgumentNullException(nameof(context));
        _logger = logger ?? throw new ArgumentNullException(nameof(logger));
    }

    /// <summary>
    /// Seed the database with initial data.
    /// Entities are seeded in multiple passes to handle FK dependencies.
    /// </summary>
    public async Task SeedAsync()
    {
        _logger.LogInformation("Starting database seeding...");

        // Multiple passes to handle FK dependencies
        var maxPasses = 5;
        for (var pass = 0; pass < maxPasses; pass++)
        {
            var seeded = false;
{{- range .Project.Entities }}
{{- if .Seed }}
            seeded |= await Seed{{ .Name }}Async();
{{- end }}
{{- end }}
            if (!seeded) break;
        }

        _logger.LogInformation("Database seeding completed");
    }

{{- range .Project.Entities }}
{{- if .Seed }}
{{- $entity := . }}

    /// <summary>
    /// Seed {{ pluralize .Name | lowercase }} entity
    /// </summary>
    /// <returns>True if entities were seeded, false if skipped or failed</returns>
    private async Task<bool> Seed{{ .Name }}Async()
    {
        // Check if data already exists
        if (await _context.{{ .NamePlural }}.AnyAsync())
        {
            return false;
        }

        try
        {
            _logger.LogInformation("Seeding {{ pluralize .Name | lowercase }}...");

            var entities = new List<{{ .Name }}>
            {
{{- range .Seed }}
                new {{ $entity.Name }}
                {
{{- range $k, $v := . }}
{{- $field := lookupField $k $entity }}
{{- if $field }}
                    {{ $k | pascalcase }} = {{ template "seedValueExpression" (dict "Field" $field "Value" $v) }},
{{- else }}
                    {{ $k | pascalcase }} = {{ jsonValue $v }},
{{- end }}
{{- end }}
                },
{{- end }}
            };

            await _context.{{ .NamePlural }}.AddRangeAsync(entities);
            await _context.SaveChangesAsync();

            _logger.LogInformation("Seeded {Count} {{ pluralize .Name | lowercase }}", entities.Count);
            return true;
        }
        catch (Exception ex)
        {
            _logger.LogWarning("Failed to seed {{ pluralize .Name | lowercase }} (dependencies may not exist yet): {Message}", ex.Message);
            return false;
        }
    }
{{- end }}
{{- end }}
}
