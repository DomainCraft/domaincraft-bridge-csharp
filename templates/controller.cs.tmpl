{{- $proj := .Project.Name | pascalcase -}}
{{- $entity := .Entity.Name -}}
{{- $perms := .Permissions -}}
using System.ComponentModel.DataAnnotations;
using System.Text.Json;
using System.Text.Json.Serialization;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using {{ $proj }}.Application.Repositories;
using {{ $proj }}.Application.Security;
using {{ $proj }}.Domain.Entities;
using {{ $proj }}.Domain.Shared;

namespace {{ $proj }}.WebApi.Controllers;

/// <summary>
/// REST API Controller for {{ pluralize $entity }} resource
/// </summary>
[ApiController]
[Route("api/[controller]")]
[Produces("application/json")]
public class {{ pluralize $entity }}Controller : ControllerBase
{
    private readonly I{{ $entity }}Repository _repository;
    private readonly IPermissionService _permissionService;
    private readonly ILogger<{{ pluralize $entity }}Controller> _logger;

    public {{ pluralize $entity }}Controller(
        I{{ $entity }}Repository repository,
        IPermissionService permissionService,
        ILogger<{{ pluralize $entity }}Controller> logger)
    {
        _repository = repository ?? throw new ArgumentNullException(nameof(repository));
        _permissionService = permissionService ?? throw new ArgumentNullException(nameof(permissionService));
        _logger = logger ?? throw new ArgumentNullException(nameof(logger));
    }

    /// <summary>
    /// Get all {{ pluralize $entity | lowercase }}
    /// </summary>
{{- template "authOrAuthorize" (dict "Roles" (and $perms $perms.Read) "PermsDefined" (ne $perms nil) "Entity" $entity "Op" "Read") }}
    [HttpGet]
    [ProducesResponseType(typeof(List<{{ $entity }}Dto>), StatusCodes.Status200OK)]
    public async Task<ActionResult<List<{{ $entity }}Dto>>> GetAll()
    {
        _logger.LogInformation("GET /api/{{ pluralize $entity | lowercase }} - retrieving all {{ pluralize $entity | lowercase }}");
        var entities = await _repository.GetAllAsync();
        var dtos = entities.Select(e => MapToDto(e)).ToList();
        return Ok(dtos);
    }

    /// <summary>
    /// Get a specific {{ $entity | lowercase }} by ID
    /// </summary>
{{- template "authOrAuthorize" (dict "Roles" (and $perms $perms.Read) "PermsDefined" (ne $perms nil) "Entity" $entity "Op" "Read") }}
    [HttpGet("{id}")]
    [ProducesResponseType(typeof({{ $entity }}Dto), StatusCodes.Status200OK)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    public async Task<ActionResult<{{ $entity }}Dto>> GetById(Guid id)
    {
        _logger.LogInformation("GET /api/{{ pluralize $entity | lowercase }}/{id}", id);
        var entity = await _repository.GetByIdAsync(id);
        if (entity == null)
        {
            _logger.LogWarning("{{ $entity }} with ID {id} not found", id);
            return NotFound();
        }
        var dto = MapToDto(entity);
        return Ok(dto);
    }

    /// <summary>
    /// Create a new {{ $entity | lowercase }}
    /// </summary>
{{- template "authOrAuthorize" (dict "Roles" (and $perms $perms.Create) "PermsDefined" (ne $perms nil) "Entity" $entity "Op" "Create") }}
    [HttpPost]
    [ProducesResponseType(typeof({{ $entity }}Dto), StatusCodes.Status201Created)]
    [ProducesResponseType(StatusCodes.Status400BadRequest)]
    public async Task<ActionResult<{{ $entity }}Dto>> Create([FromBody] Create{{ $entity }}Request request)
    {
        _logger.LogInformation("POST /api/{{ pluralize $entity | lowercase }} - creating new {{ $entity | lowercase }}");

        var entity = new {{ $entity }}();
        MapCreateRequestToEntity(request, entity);

{{- if .HasAuditLog }}
        entity.CreatedBy = GetCurrentUserId();
        entity.UpdatedBy = GetCurrentUserId();
{{- end }}

        await _repository.AddAsync(entity);
        await _repository.SaveChangesAsync();
        var dto = MapToDto(entity);
        return CreatedAtAction(nameof(GetById), new { id = entity.{{ if .PrimaryKey }}{{ .PrimaryKey.Name | pascalcase }}{{ else }}Id{{ end }} }, dto);
    }

    /// <summary>
    /// Update an existing {{ $entity | lowercase }}
    /// </summary>
{{- template "authOrAuthorize" (dict "Roles" (and $perms $perms.Update) "PermsDefined" (ne $perms nil) "Entity" $entity "Op" "Update") }}
    [HttpPut("{id}")]
    [ProducesResponseType(typeof({{ $entity }}Dto), StatusCodes.Status200OK)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    [ProducesResponseType(StatusCodes.Status400BadRequest)]
    public async Task<ActionResult<{{ $entity }}Dto>> Update(Guid id, [FromBody] Update{{ $entity }}Request request)
    {
        _logger.LogInformation("PUT /api/{{ pluralize $entity | lowercase }}/{id}", id);
        var existingEntity = await _repository.GetByIdAsync(id);
        if (existingEntity == null)
        {
            _logger.LogWarning("{{ $entity }} with ID {id} not found for update", id);
            return NotFound();
        }
{{- if and $perms $perms.Update (hasOwnershipToken $perms.Update) }}
        // @Owner check: verify entity ownership for non-admin users
        if (!_permissionService.HasAnyRole(new[] { "Admin" }) && !_permissionService.IsOwner(existingEntity))
        {
            return Forbid();
        }
{{- end }}
        MapUpdateRequestToEntity(request, existingEntity);

{{- if .HasOptimisticLock }}
        if (request.Version.HasValue)
        {
            existingEntity.Version = request.Version.Value;
        }
{{- end }}
{{- if .HasAuditLog }}
        existingEntity.UpdatedBy = GetCurrentUserId();
{{- end }}

        _repository.Update(existingEntity);
        await _repository.SaveChangesAsync();
        var dto = MapToDto(existingEntity);
        return Ok(dto);
    }

    /// <summary>
    /// Delete a {{ $entity | lowercase }}
    /// </summary>
{{- template "authOrAuthorize" (dict "Roles" (and $perms $perms.Delete) "PermsDefined" (ne $perms nil) "Entity" $entity "Op" "Delete") }}
    [HttpDelete("{id}")]
    [ProducesResponseType(StatusCodes.Status204NoContent)]
    [ProducesResponseType(StatusCodes.Status404NotFound)]
    public async Task<IActionResult> Delete(Guid id)
    {
        _logger.LogInformation("DELETE /api/{{ pluralize $entity | lowercase }}/{id}", id);
        var entity = await _repository.GetByIdAsync(id);
        if (entity == null)
        {
            _logger.LogWarning("{{ $entity }} with ID {id} not found for deletion", id);
            return NotFound();
        }
{{- if and $perms $perms.Delete (hasOwnershipToken $perms.Delete) }}
        // @Owner check: verify entity ownership for non-admin users
        if (!_permissionService.HasAnyRole(new[] { "Admin" }) && !_permissionService.IsOwner(entity))
        {
            return Forbid();
        }
{{- end }}
{{- if .HasSoftDelete }}
        entity.DeletedAt = DateTime.UtcNow;
        _repository.Update(entity);
        await _repository.SaveChangesAsync();
{{- else }}
        _repository.Delete(entity);
        await _repository.SaveChangesAsync();
{{- end }}

        _logger.LogInformation("{{ $entity }} with ID {id} deleted successfully", id);
        return NoContent();
    }

{{- if and .Seed (gt (len .Seed) 0) }}

    /// <summary>
    /// Seed {{ pluralize $entity | lowercase }} with sample data
    /// </summary>
    [Authorize]
    [HttpPost("seed")]
    [ProducesResponseType(StatusCodes.Status200OK)]
    public async Task<IActionResult> Seed()
    {
        var entities = new List<{{ $entity }}>();
{{- range .Seed }}
        entities.Add(new {{ $entity }}
        {
{{- range $key, $value := . }}
{{- $field := lookupField $key $.Entity }}
{{- $target := $key | pascalcase -}}
{{- if $field -}}
{{- if $field.IsRelation }}{{ $target = print $target "Id" }}{{ end }}
            {{ $target }} = {{ template "seedValueExpression" (dict "Field" $field "Value" $value) }},
{{- end }}
{{- end }}
        });
{{- end }}
        foreach (var entity in entities)
        {
            await _repository.AddAsync(entity);
        }
        await _repository.SaveChangesAsync();

        return Ok(new { message = $"Seeded {entities.Count} {{ pluralize $entity | lowercase }}" });
    }
{{- end }}

    // ===================== DTOs =====================

    public class {{ $entity }}Dto
    {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if .IsPrimary }}
        public {{ languageType .DatabaseType .IsNullable }} {{ .Name | pascalcase }} { get; set; }
{{- else }}
{{- template "dtoFieldProperties" . }}
{{- end }}
{{- end }}
{{- if .HasAudit }}
        public DateTime CreatedAt { get; set; }
        public DateTime UpdatedAt { get; set; }
{{- end }}
{{- if .HasAuditLog }}
        public Guid CreatedBy { get; set; }
        public Guid UpdatedBy { get; set; }
{{- end }}
{{- if .HasSoftDelete }}
        public DateTime? DeletedAt { get; set; }
{{- end }}
{{- if .HasOptimisticLock }}
        public int Version { get; set; }
{{- end }}
    }

    public class Create{{ $entity }}Request
    {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if not .IsPrimary }}
{{- template "requestFieldProperties" . }}
{{- end }}
{{- end }}
    }

    public class Update{{ $entity }}Request
    {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if not .IsPrimary }}
{{- template "requestFieldProperties" . }}
{{- end }}
{{- end }}
{{- if .HasOptimisticLock }}
        [JsonPropertyName("version")]
        public int? Version { get; set; }
{{- end }}
    }

    // ===================== Mappers =====================

    private {{ $entity }}Dto MapToDto({{ $entity }} entity)
    {
        return new {{ $entity }}Dto
        {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if .IsPrimary }}
            {{ .Name | pascalcase }} = entity.{{ .Name | pascalcase }},
{{- else }}
{{- template "mapFieldToDto" . }}
{{- end }}
{{- end }}
{{- if .HasAudit }}
            CreatedAt = entity.CreatedAt,
            UpdatedAt = entity.UpdatedAt,
{{- end }}
{{- if .HasAuditLog }}
            CreatedBy = entity.CreatedBy,
            UpdatedBy = entity.UpdatedBy,
{{- end }}
{{- if .HasSoftDelete }}
            DeletedAt = entity.DeletedAt,
{{- end }}
{{- if .HasOptimisticLock }}
            Version = entity.Version,
{{- end }}
        };
    }

    private void MapCreateRequestToEntity(Create{{ $entity }}Request request, {{ $entity }} entity)
    {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if not .IsPrimary }}
{{- template "mapRequestToEntity" . }}
{{- end }}
{{- end }}
    }

    private void MapUpdateRequestToEntity(Update{{ $entity }}Request request, {{ $entity }} entity)
    {
{{- range .Entity.Fields }}
{{- if isFeatureField .Name }}
{{- else if not .IsPrimary }}
{{- template "mapRequestToEntity" . }}
{{- end }}
{{- end }}
    }

    private Guid GetCurrentUserId()
    {
        var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
            ?? User.FindFirst("sub")?.Value;
        if (Guid.TryParse(userIdClaim, out var userId))
        {
            return userId;
        }
        return Guid.Empty;
    }
}
