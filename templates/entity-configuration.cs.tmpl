using System.Text.Json;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;
using Microsoft.EntityFrameworkCore.Storage.ValueConversion;
using {{ .Project.Name | pascalcase }}.Domain.Entities;

namespace {{ .Project.Name | pascalcase }}.Infrastructure.Persistence.Configurations;

/// <summary>
/// EF Core configuration for {{ .Entity.Name }}
/// </summary>
public class {{ .Entity.Name }}Configuration : IEntityTypeConfiguration<{{ .Entity.Name }}>
{
    public void Configure(EntityTypeBuilder<{{ .Entity.Name }}> builder)
    {
        // Table
        builder.ToTable("{{ .Entity.NamePlural | snakecase }}");

        // Primary Key
{{- range .Entity.Fields }}
{{- if .IsPrimary }}
        builder.HasKey(e => e.{{ .Name | pascalcase }});
        builder.Property(e => e.{{ .Name | pascalcase }}).HasColumnName("{{ .Name | snakecase }}");
{{- end }}
{{- end }}

        // Properties
{{- range .Entity.Fields }}
{{- if and (not .IsRelation) (not .IsPrimary) (not (isFeatureField .Name)) }}
{{- $colName := .Name | snakecase }}
{{- $propName := .Name | pascalcase }}
{{- if isEnumType .DatabaseType }}
        builder.Property(e => e.{{ $propName }})
            .HasColumnName("{{ $colName }}")
            .HasConversion<string>()
            .HasMaxLength(50)
{{- if not .IsNullable }}
            .IsRequired()
{{- end }};
{{- else if or (eq .DatabaseType "json") (eq .DatabaseType "jsonb") }}
        builder.Property(e => e.{{ $propName }})
            .HasColumnName("{{ $colName }}")
            .HasConversion(
                new ValueConverter<JsonDocument?, string>(
                    v => v == null ? null : v.RootElement.GetRawText(),
                    v => v == null ? null : JsonDocument.Parse(v, default)
                )
            );
{{- else if eq .DatabaseType "string" }}
{{- $maxLen := 255 }}
{{- if .HasValidation "max" }}
{{- $maxLen = .ValidationValue "max" }}
{{- end }}
        builder.Property(e => e.{{ $propName }})
            .HasColumnName("{{ $colName }}")
            .HasMaxLength({{ $maxLen }})
{{- if not .IsNullable }}
            .IsRequired()
{{- end }};
{{- else if eq .DatabaseType "text" }}
        builder.Property(e => e.{{ $propName }})
            .HasColumnName("{{ $colName }}")
{{- if not .IsNullable }}
            .IsRequired()
{{- end }};
{{- else }}
        builder.Property(e => e.{{ $propName }})
            .HasColumnName("{{ $colName }}");
{{- end }}
{{- if .IsUnique }}
        builder.HasIndex(e => e.{{ $propName }}).IsUnique();
{{- end }}
{{- end }}
{{- end }}

        // Indexes
{{- range .Entity.Indexes }}
        builder
            .HasIndex(e => new { {{- range $i, $field := .Fields }}{{ if $i }}, {{ end }}e.{{ $field | pascalcase }}{{- end }} })
            .HasDatabaseName("IX_{{ .Name | snakecase }}")
{{- if .Unique }}
            .IsUnique()
{{- end }};
{{- end }}

        // Relations
{{- range .Entity.RelationsOut }}
{{- if not .IsMany }}
        // {{ .FieldName }} -> {{ .TargetEntity.Name }}
{{- $navName := .NavigationName | pascalcase }}
{{- $fkName := fkName .FieldName | pascalcase }}
{{- $fkColName := fkName .FieldName | snakecase }}
        builder
            .HasOne(e => e.{{ $navName }})
            .WithMany(e => e.{{ .InverseNavName | pascalcase }})
            .HasForeignKey(e => e.{{ $fkName }})
            .OnDelete(DeleteBehavior.{{ deleteBehaviorName .OnDeleteBehavior }})
            .IsRequired({{ if .IsNullable }}false{{ else }}true{{ end }});
        builder.Property(e => e.{{ $fkName }}).HasColumnName("{{ $fkColName }}");
{{- end }}
{{- end }}

        // Soft Delete Query Filter
{{- $hasSoftDelete := .Entity.HasSoftDelete }}
{{- $hasSoftNav := false }}
{{- range .Entity.RelationsOut }}
{{- if and .TargetEntity.HasSoftDelete (not .IsMany) }}
{{- $hasSoftNav = true }}
{{- end }}
{{- end }}
{{- if or $hasSoftDelete $hasSoftNav }}
{{- $first := true }}
        builder.HasQueryFilter(e =>
{{- if $hasSoftDelete }}
 e.DeletedAt == null{{ $first = false }}
{{- end }}
{{- range .Entity.RelationsOut }}
{{- if and .TargetEntity.HasSoftDelete (not .IsMany) }}
{{- if not $first }}
            &&
{{- end }}
 e.{{ .NavigationName | pascalcase }}.DeletedAt == null{{ $first = false }}
{{- end }}
{{- end }}
        );
{{- end }}

        // Audit properties
{{- if .Entity.HasAudit }}
        builder.Property(e => e.CreatedAt)
            .HasColumnName("created_at")
            .HasDefaultValueSql("CURRENT_TIMESTAMP")
            .ValueGeneratedOnAdd();

        builder.Property(e => e.UpdatedAt)
            .HasColumnName("updated_at")
            .HasDefaultValueSql("CURRENT_TIMESTAMP")
            .ValueGeneratedOnAddOrUpdate();
{{- end }}
{{- if .Entity.HasAuditLog }}
        builder.Property(e => e.CreatedBy).HasColumnName("created_by");
        builder.Property(e => e.UpdatedBy).HasColumnName("updated_by");
{{- end }}
{{- if .Entity.HasSoftDelete }}
        builder.Property(e => e.DeletedAt).HasColumnName("deleted_at");
{{- end }}

        // Concurrency token
{{- if .Entity.HasOptimisticLock }}
        builder.Property(e => e.Version)
            .HasColumnName("version")
            .IsConcurrencyToken()
            .HasDefaultValue(1);
{{- end }}
    }
}
