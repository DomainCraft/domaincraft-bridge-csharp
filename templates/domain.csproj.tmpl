<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>{{ or .Project.Platform "net10.0" }}</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>{{ .Project.Name | pascalcase }}.Domain</RootNamespace>
    <AssemblyName>{{ .Project.Name | pascalcase }}.Domain</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="{{ index .Packages "json_serialization" }}" />
  </ItemGroup>
</Project>
