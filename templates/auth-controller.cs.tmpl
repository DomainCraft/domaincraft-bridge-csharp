using System.IdentityModel.Tokens.Jwt;
using System.Security.Claims;
using System.Text;
using System.Text.Json;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using Microsoft.IdentityModel.Tokens;
using {{ .Project.Name | pascalcase }}.Domain.Shared;
using {{ .Project.Name | pascalcase }}.Infrastructure.Persistence;

namespace {{ .Project.Name | pascalcase }}.WebApi.Controllers;

[ApiController]
[Route("api/{{ .Project.Auth.Entity | lowercase }}")]
public class {{ .Project.Auth.Entity }}Controller : ControllerBase
{
    private readonly DomainDbContext _context;
    private readonly IConfiguration _configuration;

    public {{ .Project.Auth.Entity }}Controller(DomainDbContext context, IConfiguration configuration)
    {
        _context = context;
        _configuration = configuration;
    }

{{- if .Project.Auth.Endpoints.HasLogin }}
    [HttpPost("login")]
    [AllowAnonymous]
    public async Task<IActionResult> Login([FromBody] LoginRequest request)
    {
        var entity = await _context.{{ .Project.Auth.Entity | pluralize }}
            .FirstOrDefaultAsync(e => EF.Property<string>(e, "Email") == request.Email);

        if (entity == null)
            return Unauthorized(new { message = "Invalid credentials" });

        var storedPassword = entity.GetType().GetProperty("Password")?.GetValue(entity)?.ToString();
        if (storedPassword == null || storedPassword != request.Password)
            return Unauthorized(new { message = "Invalid credentials" });

        var token = GenerateJwtToken(entity);
        return Ok(new { token });
    }
{{- end }}

{{- if .Project.Auth.Endpoints.HasRegister }}
    [HttpPost("register")]
    [AllowAnonymous]
    public async Task<IActionResult> Register([FromBody] RegisterRequest request)
    {
        var exists = await _context.{{ .Project.Auth.Entity | pluralize }}
            .AnyAsync(e => EF.Property<string>(e, "Email") == request.Email);

        if (exists)
            return Conflict(new { message = "Email already registered" });

        var entity = Activator.CreateInstance<{{ .Project.Name | pascalcase }}.Domain.Entities.{{ .Project.Auth.Entity }}>();
        entity.GetType().GetProperty("Id")?.SetValue(entity, Guid.NewGuid());
        entity.GetType().GetProperty("Email")?.SetValue(entity, request.Email);
        entity.GetType().GetProperty("Password")?.SetValue(entity, request.Password);
{{- range $.Project.Entities }}
{{- if eq .Name $.Project.Auth.Entity }}
{{- range .Fields }}
{{- if and (not .IsPrimary) (not .IsRelation) (not (isFeatureField .Name)) (ne .Name "email") (ne .Name "password") (ne .Name "Email") (ne .Name "Password") }}
{{- if or .DefaultValue (not .IsNullable) }}
        entity.GetType().GetProperty("{{ .Name | pascalcase }}")?.SetValue(entity, {{ template "defaultValueExpression" . }});
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

        _context.{{ .Project.Auth.Entity | pluralize }}.Add(entity);
        await _context.SaveChangesAsync();

        return Created();
    }
{{- end }}

{{- if .Project.Auth.Endpoints.HasMe }}
    [HttpGet("me")]
    [Authorize]
    public async Task<IActionResult> Me()
    {
        var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("sub")?.Value;
        if (userId == null || !Guid.TryParse(userId, out var id))
            return Unauthorized();

        var entity = await _context.{{ .Project.Auth.Entity | pluralize }}.FindAsync(id);
        if (entity == null)
            return NotFound();

        return Ok(entity);
    }
{{- end }}

    private string GenerateJwtToken(object entity)
    {
        var secret = _configuration["Jwt:Secret"] ?? throw new InvalidOperationException("JWT secret not configured");
        var key = new SymmetricSecurityKey(Encoding.ASCII.GetBytes(secret));
        var credentials = new SigningCredentials(key, SecurityAlgorithms.HmacSha256);

        var id = entity.GetType().GetProperty("Id")?.GetValue(entity)?.ToString() ?? "";
        var email = entity.GetType().GetProperty("Email")?.GetValue(entity)?.ToString() ?? "";

        var claims = new[]
        {
            new Claim(ClaimTypes.NameIdentifier, id),
            new Claim(ClaimTypes.Email, email),
            new Claim(JwtRegisteredClaimNames.Sub, id),
        };

        var token = new JwtSecurityToken(
            issuer: _configuration["Jwt:Issuer"],
            audience: _configuration["Jwt:Audience"],
            claims: claims,
            expires: DateTime.UtcNow.AddMinutes(Convert.ToDouble(_configuration["Jwt:ExpirationMinutes"] ?? "60")),
            signingCredentials: credentials
        );

        return new JwtSecurityTokenHandler().WriteToken(token);
    }
}

public class LoginRequest
{
    public string Email { get; set; } = "";
    public string Password { get; set; } = "";
}

public class RegisterRequest
{
    public string Email { get; set; } = "";
    public string Password { get; set; } = "";
    public string Name { get; set; } = "";
}
