using System;
using System.Collections.Generic;
using System.Linq;
using System.Security.Claims;
using Microsoft.AspNetCore.Http;

namespace {{ .Project.Name | pascalcase }}.Application.Security;

/// <summary>
/// Basic implementation of <see cref="IPermissionService"/> that reads roles from
/// the current <see cref="ClaimsPrincipal"/>. Bridges are free to replace this
/// with an application-specific implementation (e.g. checking tenant, group memberships,
/// ownership rules, external policy stores, etc.).
/// </summary>
public class PermissionService : IPermissionService
{
    private readonly ClaimsPrincipal _user;
    private readonly IOwnerResolver? _ownerResolver;

    public PermissionService(IHttpContextAccessor httpContextAccessor, IOwnerResolver? ownerResolver = null)
    {
        _user = httpContextAccessor?.HttpContext?.User
            ?? throw new ArgumentNullException(nameof(httpContextAccessor));
        _ownerResolver = ownerResolver;
    }

    public bool HasAnyRole(IEnumerable<string> roles)
    {
        if (roles == null) return false;

        // If policies include "*" then treat as public (accessible to everyone, including anonymous)
        if (roles.Contains("*"))
        {
            return true;
        }

        var userRoles = _user?.Claims
            .Where(c => c.Type == ClaimTypes.Role || c.Type == "role")
            .Select(c => c.Value)
            .ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Direct role match
        // Note: @Owner tokens are filtered by the caller (controller) and handled
        // via IPermissionService.IsOwner() separately. HasAnyRole only matches role strings.
        foreach (var role in roles)
        {
            if (userRoles.Contains(role)) return true;
        }

        return false;
    }

    public bool IsInRole(string role)
    {
        if (string.IsNullOrWhiteSpace(role)) return false;
        return _user?.IsInRole(role) ?? false;
    }

    public bool IsOwner(object entity)
    {
        if (entity == null) return false;
        if (_ownerResolver != null)
        {
            return _ownerResolver.IsOwner(_user, entity);
        }

        // Ownership resolution requires IOwnerResolver implementation
        // Register a custom IOwnerResolver in your DI container to enable @Owner checks
        return false;
    }
}
