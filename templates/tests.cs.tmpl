    public ApiTests(WebApplicationFactory<Program> factory)
    {
        _factory = factory.WithWebHostBuilder(builder =>
        {
            builder.UseEnvironment("Testing");

            builder.ConfigureAppConfiguration((context, config) =>
            {
                // Provide test configuration values
                config.AddInMemoryCollection(new Dictionary<string, string?>
                {
                    ["Jwt:Secret"] = "TestSecretKey123456789012345678901234567890",
                    ["Jwt:Issuer"] = "test-issuer",
                    ["Jwt:Audience"] = "test-audience",
                    ["ConnectionStrings:PostgreSQL"] = "Host=localhost;Database=test",
                    ["ConnectionStrings:Redis"] = "",
                });
            });

            builder.ConfigureServices(services =>
            {
                // Remove real database and seeder
                var descriptors = services.Where(d =>
                    d.ServiceType == typeof(DbContextOptions<DomainDbContext>) ||
                    d.ServiceType == typeof(DomainDbContext) ||
                    d.ImplementationType == typeof(DomainSeeder))
                    .ToList();
                foreach (var d in descriptors) services.Remove(d);

                // Replace with in-memory database
                services.AddDbContext<DomainDbContext>(options =>
                {
                    options.UseInMemoryDatabase(_dbName);
                });

                // Remove the ICacheService registration and add a no-op one
                var cacheDescriptors = services.Where(d =>
                    d.ServiceType?.Name == "ICacheService")
                    .ToList();
                foreach (var d in cacheDescriptors) services.Remove(d);
                services.AddSingleton<{{ $proj }}.Application.Caching.ICacheService, {{ $proj }}.Tests.NoOpCacheService>();
            });
        });
        _client = _factory.CreateClient();

        using var scope = _factory.Services.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<DomainDbContext>();
        context.Database.EnsureCreated();
    }

    public async Task InitializeAsync() => await SeedTestEntities();
    public Task DisposeAsync() => Task.CompletedTask;

