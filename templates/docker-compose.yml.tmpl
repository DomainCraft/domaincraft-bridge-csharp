services:
  # PostgreSQL Database
  postgres:
    image: postgres:16-alpine
    container_name: {{ .Project.Name | snakecase }}-postgres
    environment:
      POSTGRES_DB: {{ .Project.Name }}_db
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

{{- if and .Project.Cache .Project.Cache.Enabled }}

  # {{ .Project.Cache.Provider | default "redis" | title }} Cache
  cache:
    image: {{ if eq .Project.Cache.Provider "memcached" }}memcached:1-alpine{{ else }}redis:7-alpine{{ end }}
    container_name: {{ .Project.Name | snakecase }}-cache
    ports:
      - "{{ if eq .Project.Cache.Provider "memcached" }}11211{{ else }}6379{{ end }}:{{ if eq .Project.Cache.Provider "memcached" }}11211{{ else }}6379{{ end }}"
    volumes:
      - cache_data:/data
    healthcheck:
      test: ["CMD", "{{ if eq .Project.Cache.Provider "memcached" }}echo stats | nc localhost 11211{{ else }}redis-cli{{ end }}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{{- end }}

  # Application
  api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{ .Project.Name | snakecase }}-api
    ports:
      - "8080:8080"
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - ConnectionStrings__PostgreSQL=Host=postgres;Database={{ .Project.Name }}_db;Username=postgres;Password=postgres
{{- if and .Project.Cache .Project.Cache.Enabled .Project.Cache.ConnectionString }}
      - ConnectionStrings__Redis={{ .Project.Cache.ConnectionString }}
{{- end }}
{{- if .Project.HasAuth }}
      - Jwt__Secret=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
      - Jwt__Issuer={{ .Project.Name }}
      - Jwt__Audience={{ .Project.Name | snakecase }}-api
{{- end }}
    depends_on:
      postgres:
        condition: service_healthy
{{- if and .Project.Cache .Project.Cache.Enabled }}
      cache:
        condition: service_healthy
{{- end }}
    restart: unless-stopped

volumes:
  postgres_data:
{{- if and .Project.Cache .Project.Cache.Enabled }}
  cache_data:
{{- end }}
